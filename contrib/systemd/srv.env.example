# Copy this file to /etc/srv/srv.env and fill in the required values.
#
# Required for the control-plane node join. After the first successful start,
# tsnet state under SRV_DATA_DIR/state/tsnet usually persists the node identity,
# but keeping TS_AUTHKEY configured is the simplest setup.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx

# Required for minting one-off guest auth keys during `ssh srv new NAME`.
TS_CLIENT_ID=your-oauth-client-id
TS_CLIENT_SECRET=your-oauth-client-secret
TS_TAILNET=your-tailnet.ts.net

# Core srv settings.
SRV_HOSTNAME=srv
SRV_LISTEN_ADDR=:22
SRV_DATA_DIR=/var/lib/srv
SRV_NET_HELPER_SOCKET=/run/srv/net-helper.sock
SRV_VM_RUNNER_SOCKET=/run/srv-vm-runner/vm-runner.sock
# The installer downloads the official static Firecracker release pair here by default.
SRV_FIRECRACKER_BIN=/usr/local/bin/firecracker
SRV_JAILER_BIN=/usr/local/bin/jailer
# SRV_JAILER_BASE_DIR=/var/lib/srv/jailer
# SRV_JAILER_USER=srv-vm
# SRV_JAILER_GROUP=srv

# Base guest artifacts.
SRV_BASE_KERNEL=/var/lib/srv/images/arch-base/vmlinux
SRV_BASE_ROOTFS=/var/lib/srv/images/arch-base/rootfs-base.img
# SRV_BASE_INITRD=

# Required so minted guest keys carry an allowed tag.
SRV_GUEST_AUTH_TAGS=tag:microvm

# Optional controls.
# SRV_ALLOWED_USERS=alice@example.com,bob@example.com
# SRV_ADMIN_USERS=ops@example.com
# SRV_ADVERTISE_TAGS=tag:microvm-control
# SRV_OUTBOUND_IFACE=eth0
# SRV_VM_NETWORK_CIDR=172.28.0.0/16
# SRV_VM_DNS=1.1.1.1,1.0.0.1
# SRV_GUEST_AUTH_EXPIRY=15m
# SRV_GUEST_READY_TIMEOUT=2m
# SRV_VM_VCPUS=1
# SRV_VM_MEMORY_MIB=1024
# SRV_VM_PIDS_MAX=512
# SRV_LOG_LEVEL=info
# SRV_ZEN_API_KEY=
# SRV_ZEN_BASE_URL=https://opencode.ai/zen
# SRV_ZEN_GATEWAY_PORT=11434

# Alternate control-plane endpoints, for example when using Headscale.
# TS_CONTROL_URL=
# TS_API_BASE_URL=
# SRV_GUEST_TAILSCALE_CONTROL_URL=

# Extra guest kernel arguments appended to the Firecracker boot line.
# SRV_EXTRA_KERNEL_ARGS=
