[Unit]
Description=srv privileged network helper
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=root
Group=root
RuntimeDirectory=srv
RuntimeDirectoryMode=0755
ExecStart=/usr/local/bin/srv-net-helper -socket /run/srv/net-helper.sock -tap-user srv-vm -client-group srv
NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=yes
RestrictSUIDSGID=yes
LockPersonality=yes
SystemCallArchitectures=native
RestrictRealtime=yes
CapabilityBoundingSet=CAP_CHOWN CAP_NET_ADMIN CAP_NET_RAW
AmbientCapabilities=CAP_CHOWN CAP_NET_ADMIN CAP_NET_RAW
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
