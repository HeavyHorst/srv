CONFIG_TUN=y
# Firecracker's SendCtrlAltDel action is delivered through the emulated i8042
# keyboard controller on x86, so keep the minimal input stack enabled.
CONFIG_INPUT_KEYBOARD=y
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_MODULES=y
# Firecracker's x86 ACPI boot path still needs CONFIG_PCI in the guest even
# when the VMM is exposing virtio devices over MMIO rather than PCI transport.
CONFIG_PCI=y
# Prefer ACPI device discovery on x86_64 instead of the older duplicated
# virtio-mmio kernel-command-line mechanism.
# CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES is not set
CONFIG_VIRTIO_BALLOON=y
CONFIG_BALLOON_COMPACTION=y
CONFIG_PAGE_REPORTING=y
# Keep Docker's bridge and storage pieces modular so the guest rootfs gets a
# real /lib/modules tree and systemd-modules-load can satisfy docker.conf.
CONFIG_VETH=m
CONFIG_BRIDGE=m
CONFIG_BRIDGE_NETFILTER=m
CONFIG_NF_TABLES_BRIDGE=m
CONFIG_NF_CONNTRACK_BRIDGE=m
CONFIG_OVERLAY_FS=m
CONFIG_WIREGUARD=y
CONFIG_CRYPTO_CURVE25519=y
CONFIG_CRYPTO_CURVE25519_X86=y
CONFIG_CRYPTO_CHACHA20=y
CONFIG_CRYPTO_CHACHA20_X86_64=y
CONFIG_CRYPTO_CHACHA20POLY1305=y
CONFIG_CRYPTO_POLY1305=y
CONFIG_CRYPTO_POLY1305_X86_64=y
CONFIG_CRYPTO_BLAKE2S=y
CONFIG_CRYPTO_BLAKE2S_X86=y
CONFIG_CRYPTO_LIB_CHACHA=y
CONFIG_CRYPTO_LIB_CURVE25519=y
CONFIG_CRYPTO_LIB_CHACHA20POLY1305=y
CONFIG_CRYPTO_LIB_POLY1305=y
CONFIG_CRYPTO_GHASH=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_RAW=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
# Arch's iptables-nft backend needs the IPv4/IPv6 nf_tables families, not just
# the generic nf_tables core, or `nft add table ip ...` fails at runtime.
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_CT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_REJECT=y
CONFIG_POSIX_MQUEUE=y
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
# Pacman 7 uses a Landlock-backed download sandbox when DownloadUser is set.
# Keep Landlock in the built-in LSM list so package installs inside the guest
# work without disabling pacman's sandbox.
CONFIG_SECURITY_LANDLOCK=y
CONFIG_LSM="landlock,lockdown,yama,integrity,bpf"
# CONFIG_SECURITY_SELINUX is not set
