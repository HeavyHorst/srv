CONFIG_TUN=y
# Firecracker's x86 ACPI boot path still needs CONFIG_PCI in the guest even
# when the VMM is exposing virtio devices over MMIO rather than PCI transport.
CONFIG_PCI=y
# Prefer ACPI device discovery on x86_64 instead of the older duplicated
# virtio-mmio kernel-command-line mechanism.
# CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES is not set
CONFIG_WIREGUARD=y
CONFIG_CRYPTO_CURVE25519=y
CONFIG_CRYPTO_CURVE25519_X86=y
CONFIG_CRYPTO_CHACHA20=y
CONFIG_CRYPTO_CHACHA20_X86_64=y
CONFIG_CRYPTO_CHACHA20POLY1305=y
CONFIG_CRYPTO_POLY1305=y
CONFIG_CRYPTO_POLY1305_X86_64=y
CONFIG_CRYPTO_BLAKE2S=y
CONFIG_CRYPTO_BLAKE2S_X86=y
CONFIG_CRYPTO_LIB_CHACHA=y
CONFIG_CRYPTO_LIB_CURVE25519=y
CONFIG_CRYPTO_LIB_CHACHA20POLY1305=y
CONFIG_CRYPTO_LIB_POLY1305=y
CONFIG_CRYPTO_GHASH=y
CONFIG_NF_TABLES=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_CT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_META=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_REJECT=y
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
# Pacman 7 uses a Landlock-backed download sandbox when DownloadUser is set.
# Keep Landlock in the built-in LSM list so package installs inside the guest
# work without disabling pacman's sandbox.
CONFIG_SECURITY_LANDLOCK=y
CONFIG_LSM="landlock,lockdown,yama,integrity,bpf"
# CONFIG_SECURITY_SELINUX is not set
